    "executor": "async (args) => ({ results: ['result1', 'result2'] })"
  },
  "invocation": {
    "toolName": "web_search",
    "args": { "query": "TypeScript best practices" },
    "reason": "User asked about TypeScript",
    "requestedBy": { "type": "assistant" }
  }
}
