{
  "name": "@agora/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "./dist-electron/main/index.js",
  "description": "Local-first multi-role council room document assistant",
  "author": "Ezri-Lin",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "npx tsc -p tsconfig.electron.json && NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5200 npx electron .",
    "build": "vite build && npx tsc -p tsconfig.electron.json",
    "dist": "pnpm build && npx electron-builder",
    "dist:mac": "pnpm build && npx electron-builder --mac",
    "dist:win": "pnpm build && npx electron-builder --win",
    "dist:linux": "pnpm build && npx electron-builder --linux",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.agora.desktop",
    "productName": "Agora",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/renderer/**/*",
      "src/preload/index.js"
    ],
    "mac": {
      "target": "dmg",
      "icon": null
    },
    "win": {
      "target": "nsis",
      "icon": null
    },
    "linux": {
      "target": "AppImage",
      "icon": null
    }
  },
  "dependencies": {
    "@agora/kernel": "workspace:*",
    "@agora/memory": "workspace:*",
    "@agora/roles": "workspace:*",
    "@agora/room-store": "workspace:*",
    "@agora/shared": "workspace:*",
    "@agora/vault-adapter": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
