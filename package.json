{
  "name": "agora",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, memory-aware, multi-role council room document assistant",
  "scripts": {
    "dev": "pnpm --filter @agora/desktop dev:vite & sleep 3 && pnpm --filter @agora/desktop dev:electron",
    "build": "vite build apps/desktop/vite.config.ts",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "eval": "tsx packages/kernel/src/eval/cli.ts",
    "eval:context": "tsx eval/run-context-eval.ts --mode contract",
    "eval:context:compression": "tsx eval/run-context-eval.ts --mode compression",
    "eval:context:ci": "tsx eval/run-context-eval.ts --mode compression --compressor rule-based --ci",
    "eval:context:rule-based": "tsx eval/run-context-eval.ts --mode compression --compressor rule-based",
    "eval:context:llm": "tsx eval/run-context-eval.ts --mode compression --compressor llm",
    "eval:runtime-compression": "tsx eval/run-runtime-compression-eval.ts",
    "eval:runtime-compression:ci": "tsx eval/run-runtime-compression-eval.ts --ci",
    "eval:memory-candidates": "tsx eval/run-memory-candidates-eval.ts",
    "eval:memory-candidates:ci": "tsx eval/run-memory-candidates-eval.ts --ci",
    "eval:memory-extraction": "tsx eval/run-memory-extraction-eval.ts --extractor rule-based",
    "eval:memory-extraction:llm": "tsx eval/run-memory-extraction-eval.ts --extractor llm",
    "eval:memory-extraction:ci": "tsx eval/run-memory-extraction-eval.ts --extractor rule-based --ci",
    "eval:memory-store": "tsx eval/run-memory-store-eval.ts",
    "eval:memory-store:ci": "tsx eval/run-memory-store-eval.ts --ci",
    "eval:memory-retrieval": "tsx eval/run-memory-retrieval-eval.ts",
    "eval:memory-retrieval:ci": "tsx eval/run-memory-retrieval-eval.ts --ci",
    "eval:memory-consolidation": "tsx eval/run-memory-consolidation-eval.ts",
    "eval:memory-consolidation:ci": "tsx eval/run-memory-consolidation-eval.ts --ci",
    "eval:tool-runtime": "tsx eval/run-tool-runtime-eval.ts",
    "eval:tool-runtime:ci": "tsx eval/run-tool-runtime-eval.ts --ci",
    "eval:evidence-search": "tsx eval/run-evidence-search-eval.ts",
    "eval:evidence-search:ci": "tsx eval/run-evidence-search-eval.ts --ci"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}